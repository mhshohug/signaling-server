# Server Configuration
PORT=3000
NODE_ENV=production
CORS_ORIGIN=*

# JWT Authentication Secret (for verifying client handshake tokens, optional but recommended)
JWT_SECRET=your_super_secret_jwt_key_here

# STUN Servers (Comma-separated list of STUN URLs)
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302,stun:stun2.l.google.com:19302

# TURN Servers Configuration (JSON-string containing array of TURN config objects)
# Format: [{"urls":"turn:your-turn-server.com:3478","username":"user","credential":"password"}]
TURN_SERVERS=[]
